nextflow_pipeline {
    name "test `mag-ont` pipeline"
    script "main.nf"
    options "-profile test,docker"

    test("assemble group `ont_test4` AND use provided assemblies `ont_test3` and `coassembly` AND skip bin quality assessment") {

        expect {
            assert workflow.success
            assert workflow.trace.succeeded().size() == 48
        }
    }
}
